generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                String   @id @default(uuid())
  name              String
  email             String   @unique
  password          String
  phone             String?
  tier              String   @default("Thành viên")
  verificationLevel String   @default("Chưa xác minh")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}
